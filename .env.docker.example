# Docker Compose environment variables
APP_KEY=base64:your-32-char-key-here
APP_URL=http://localhost:8081
APP_PORT=8081

# Optional instance branding and crawler policy
SNIPPY_PARENT_SITE_NAME=
SNIPPY_PARENT_SITE_URL=
SNIPPY_ROOT_ROBOTS_URL=
SNIPPY_ALLOW_AI_TRAINING=false

DB_DATABASE=snippy
DB_USERNAME=snippy
DB_PASSWORD=your-secure-password-here
